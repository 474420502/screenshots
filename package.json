{
  "name": "@474420502/screenshots",
  "packageManager": "pnpm@10.27.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "npm run build",
    "build": "pnpm --filter \"*\" run build",
    "test": "pnpm --filter @474420502/react-screenshots run test && pnpm --filter @474420502/electron-screenshots run test",
    "check": "biome check --write",
    "format": "biome format --write",
    "lint": "biome lint --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14"
  }
}