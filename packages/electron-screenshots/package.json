{
  "name": "@474420502/electron-screenshots",
  "version": "0.7.0",
  "description": "Extensible Electron screenshot toolkit with custom operation APIs",
  "types": "lib/index.d.ts",
  "main": "lib/index.cjs.js",
  "module": "lib/index.js",
  "type": "commonjs",
  "files": [
    "lib/**"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "start": "cross-env DEBUG=screenshots:electron electron lib/demo.js",
    "dev": "tsc --sourceMap --watch",
    "test": "npm run build && node --test test/**/*.test.mjs",
    "build": "npm run clean && tsc",
    "clean": "rimraf lib"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/474420502/screenshots.git",
    "directory": "packages/electron-screenshots"
  },
  "keywords": [
    "electron",
    "shortcut",
    "screenshot",
    "cropper"
  ],
  "author": "474420502",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/474420502/screenshots/issues"
  },
  "homepage": "https://github.com/474420502/screenshots/tree/master/packages/electron-screenshots#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "debug": "^4.4.3",
    "node-screenshots": "^0.2.8",
    "@474420502/react-screenshots": "workspace:*"
  },
  "peerDependencies": {
    "electron": ">=20"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/node": "^25.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.8.4",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3"
  }
}